{
  "rewrites": [
    { "source": "/((?!api/|@|src/|node_modules/|.*\\.).*)", "destination": "/" }
  ],
  "headers": [
    {
      "//": "Bundles de Vite — incluyen hash en el filename, son inmutables 1 año",
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "//": "Imágenes hero responsive (todas tienen hash de versión en el nombre)",
      "source": "/(hero-\\d+(?:-\\d+)?\\.(?:avif|webp|jpg|jpeg|png))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "//": "Otros assets estáticos — cache largo con revalidación",
      "source": "/(.*\\.(?:woff2|ttf|otf|svg|ico))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "//": "favicon y logo: cambian raras veces, cache 7 días con revalidación",
      "source": "/(favicon\\.png|logo\\.png)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, must-revalidate" }
      ]
    }
  ]
}